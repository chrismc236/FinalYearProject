<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night theme inherits from the main theme so nothing gets overridden -->
    <style name="Theme.FinalProject" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_coral</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/primary_coral</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:navigationBarColor">@color/card_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxStrokeColor">@color/primary_coral</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
</resources>